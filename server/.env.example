# Copy to .env and fill in. Never commit the real .env.

# --- Phase 2: Google Places (New) API ---
# Create at https://console.cloud.google.com → enable "Places API (New)" → API key
GOOGLE_PLACES_API_KEY=

# --- Phase 4: Web Push (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- Phase 4: Supabase service access (server-side push fan-out) ---
# Service role key is server-only — never expose to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Server config ---
PORT=8787
# Comma-separated list of allowed browser origins (the Vite app)
WEB_ORIGIN=http://localhost:5173,http://localhost:5180
