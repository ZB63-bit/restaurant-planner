# Copy to .env (or .env.local) and fill in. Vite only exposes VITE_* vars.

# --- Phase 2: backend proxy ---
VITE_API_BASE_URL=http://localhost:8787

# --- Phase 3: Supabase (browser-safe anon key) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Phase 4: Web Push public key (safe to expose) ---
VITE_VAPID_PUBLIC_KEY=
